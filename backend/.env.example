# ── App ──────────────────────────────────────────────
APP_NAME=CSPM Platform
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cspm:cspm_pass@localhost:5432/cspm_db
SYNC_DATABASE_URL=postgresql+psycopg2://cspm:cspm_pass@localhost:5432/cspm_db

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── JWT ──────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AWS (scanner credentials) ────────────────────────
AWS_SCANNER_ROLE_ARN=arn:aws:iam::123456789012:role/CSPMScannerRole
AWS_REGION=us-east-1

# ── GCP ──────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Azure ────────────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_SUBSCRIPTION_ID=your-subscription-id

# ── AI ───────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# ── Storage ──────────────────────────────────────────
S3_BUCKET_REPORTS=cspm-reports-bucket
S3_REGION=us-east-1

# ── Monitoring ───────────────────────────────────────
SENTRY_DSN=
ENABLE_METRICS=true

# ── Alerts ───────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
ALERT_EMAIL=security@yourcompany.com
ALERT_MIN_SEVERITY=high

# ── Email SMTP ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# ── Frontend URL (for alert links) ───────────────────────────────────
FRONTEND_URL=http://localhost:3000
