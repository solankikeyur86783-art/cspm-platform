<!-- Background Shaders & Global Effects -->
<script>
        // Simple micro-interaction for gauge
        document.addEventListener('DOMContentLoaded', () => {
            const gauge = document.querySelector('.gauge-svg circle:nth-child(2)');
            if (gauge) {
                // Animate dash offset on load
                const targetOffset = 62.8; 
                gauge.style.strokeDashoffset = '251.2';
                setTimeout(() => {
                    gauge.style.transition = 'stroke-dashoffset 2s ease-out';
                    gauge.style.strokeDashoffset = targetOffset;
                }, 300);
            }
        });
    </script>
